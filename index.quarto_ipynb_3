    "import numpy as np\n",
    "import plotly.graph_objects as go\n",
    "\n",
    "# ── Surface data ──────────────────────────────────────────────────────────────\n",
    "x_full = np.linspace(0.7, 2.3, 50)\n",
    "y_full = np.linspace(-0.2, 2.2, 50)\n",
    "Xf, Yf = np.meshgrid(x_full, y_full)\n",
    "Zf = Xf**2 + Yf**2\n",
    "\n",
    "nx, ny = 35, 35\n",
    "x_int = np.linspace(1, 2, nx)\n",
    "y_int = np.linspace(0, 2, ny)\n",
    "\n",
    "N = 20\n",
    "\n",
    "def ease(t):\n",
    "  return t * t * (3 - 2 * t)\n",
    "\n",
    "def blank_surface():\n",
    "  return go.Surface(\n",
    "    x=np.array([[1,2],[1,2]]),\n",
    "    y=np.array([[0,0],[0,0]]),\n",
    "    z=np.array([[0,0],[0,0]]),\n",
    "    colorscale=[[0,\"rgba(0,0,0,0)\"],[1,\"rgba(0,0,0,0)\"]],\n",
    "    showscale=False, opacity=0\n",
    "  )\n",
    "\n",
    "# ── Build frames ──────────────────────────────────────────────────────────────\n",
    "frames = []\n",
    "\n",
    "# Reset frame\n",
    "frames.append(go.Frame(name=\"blank\", data=[blank_surface(), blank_surface()], traces=[1, 2]))\n",
    "\n",
    "# dxdy: outer y sweeps 0 → 2, curtain moves in y-direction\n",
    "for i in range(N):\n",
    "  p = ease((i + 1) / N)\n",
    "  y_cur = 2.0 * p\n",
    "\n",
    "  y_acc = np.linspace(0, y_cur, max(2, int(ny * p) + 2))\n",
    "  Xi, Yi = np.meshgrid(x_int, y_acc)\n",
    "  Zi = Xi**2 + Yi**2\n",
    "\n",
    "  X_curt = np.vstack([x_int, x_int])\n",
    "  Y_curt = np.full((2, nx), y_cur)\n",
    "  Z_curt = np.vstack([np.zeros(nx), x_int**2 + y_cur**2])\n",
    "\n",
    "  frames.append(go.Frame(\n",
    "    name=f\"dxdy_{i}\",\n",
    "    data=[\n",
    "      go.Surface(x=Xi, y=Yi, z=Zi,\n",
    "                  colorscale=[[0,\"rgba(210,70,30,0.6)\"],[1,\"rgba(210,70,30,0.6)\"]],\n",
    "                  showscale=False, opacity=0.6),\n",
    "      go.Surface(x=X_curt, y=Y_curt, z=Z_curt,\n",
    "                  colorscale=[[0,\"rgba(255,30,0,1.0)\"],[1,\"rgba(255,30,0,1.0)\"]],\n",
    "                  showscale=False, opacity=0.95),\n",
    "    ],\n",
    "    traces=[1, 2]\n",
    "  ))\n",
    "\n",
    "# dydx: outer x sweeps 1 → 2, curtain moves in x-direction\n",
    "for i in range(N):\n",
    "  p = ease((i + 1) / N)\n",
    "  x_cur = 1.0 + 1.0 * p\n",
    "\n",
    "  x_acc = np.linspace(1, x_cur, max(2, int(nx * p) + 2))\n",
    "  Xi, Yi = np.meshgrid(x_acc, y_int)\n",
    "  Zi = Xi**2 + Yi**2\n",
    "\n",
    "  Y_curt = np.vstack([y_int, y_int])\n",
    "  X_curt = np.full((2, ny), x_cur)\n",
    "  Z_curt = np.vstack([np.zeros(ny), x_cur**2 + y_int**2])\n",
    "\n",
    "  frames.append(go.Frame(\n",
    "    name=f\"dydx_{i}\",\n",
    "    data=[\n",
    "      go.Surface(x=Xi, y=Yi, z=Zi,\n",
    "                colorscale=[[0,\"rgba(30,80,210,0.6)\"],[1,\"rgba(30,80,210,0.6)\"]],\n",
    "                showscale=False, opacity=0.6),\n",
    "      go.Surface(x=X_curt, y=Y_curt, z=Z_curt,\n",
    "                  colorscale=[[0,\"rgba(0,50,255,1.0)\"],[1,\"rgba(0,50,255,1.0)\"]],\n",
    "                  showscale=False, opacity=0.95),\n",
    "    ],\n",
    "    traces=[1, 2]\n",
    "  ))\n",
    "\n",
    "# ── Figure ────────────────────────────────────────────────────────────────────\n",
    "bx = [1, 2, 2, 1, 1]\n",
    "by = [0, 0, 2, 2, 0]\n",
    "bz = [0, 0, 0, 0, 0]\n",
    "\n",
    "fig = go.Figure(\n",
    "  data=[\n",
    "    # 0: full background surface (never touched by frames)\n",
    "    go.Surface(x=Xf, y=Yf, z=Zf,\n",
    "      colorscale=\"Viridis\", opacity=0.2, showscale=False,\n",
    "      name=\"f(x,y)\"),\n",
    "    # 1: accumulated region  (updated by frames)\n",
    "    blank_surface(),\n",
    "    # 2: sweep curtain        (updated by frames)\n",
    "    blank_surface(),\n",
    "    # 3: floor boundary       (never touched by frames)\n",
    "    go.Scatter3d(x=bx, y=by, z=bz, mode=\"lines\",\n",
    "      line=dict(color=\"black\", width=4),\n",
    "      name=\"Region boundary\"),\n",
    "  ],\n",
    "  frames=frames,\n",
    "  layout=go.Layout(\n",
    "    title=dict(text=\"∬ (x² + y²) dA   |   x ∈ [1,2],  y ∈ [0,2]\", font=dict(size=15)),\n",
    "    scene=dict(\n",
    "        xaxis=dict(title=\"x\", range=[0.7, 2.3]),\n",
    "        yaxis=dict(title=\"y\", range=[-0.2, 2.2]),\n",
    "        zaxis=dict(title=\"f(x,y) = x²+y²\"),\n",
    "        camera=dict(eye=dict(x=1.8, y=-1.8, z=1.2)),\n",
    "        aspectmode=\"manual\",\n",
    "        aspectratio=dict(x=1, y=1.5, z=1),\n",
    "    ),\n",
    "    margin=dict(l=0, r=0, t=70, b=60),\n",
    "    updatemenus=[\n",
    "      dict(\n",
    "        type=\"buttons\", showactive=False,\n",
    "        x=0.15, y=-0.05, xanchor=\"center\", yanchor=\"top\",\n",
    "        buttons=[dict(\n",
    "          label=\"▶  dx dy  (outer y)\",\n",
    "          method=\"animate\",\n",
    "          args=[[f\"dxdy_{i}\" for i in range(N)],\n",
    "            dict(frame=dict(duration=120, redraw=True),\n",
    "            transition=dict(duration=0),\n",
    "            mode=\"immediate\")]\n",
    "        )]),\n",
    "        dict(\n",
    "          type=\"buttons\", showactive=False,\n",
    "          x=0.5, y=-0.05, xanchor=\"center\", yanchor=\"top\",\n",
    "          buttons=[dict(\n",
    "            label=\"▶  dy dx  (outer x)\",\n",
    "            method=\"animate\",\n",
    "            args=[[f\"dydx_{i}\" for i in range(N)],\n",
    "              dict(frame=dict(duration=120, redraw=True),\n",
    "              transition=dict(duration=0),\n",
    "              mode=\"immediate\")]\n",
    "        )]),\n",
    "        dict(\n",
    "          type=\"buttons\", showactive=False,\n",
    "          x=0.85, y=-0.05, xanchor=\"center\", yanchor=\"top\",\n",
    "          buttons=[dict(\n",
    "            label=\"⏹  Reset\",\n",
    "            method=\"animate\",\n",
    "            args=[[\"blank\"],\n",
    "              dict(frame=dict(duration=0, redraw=True),\n",
    "              transition=dict(duration=0),\n",
    "              mode=\"immediate\")]\n",
    "        )]),\n",
    "        dict(\n",
    "          type=\"buttons\", showactive=True,\n",
    "          x=0.5, y=1.05, xanchor=\"center\", yanchor=\"top\",\n",
    "          buttons = [\n",
    "            dict(\n",
    "              label=\"⬆ Top (2D)\",\n",
    "              method=\"relayout\",\n",
    "              args=[{\"scene.camera.eye\": {\"x\": 0, \"y\": 0, \"z\": 2.5},\n",
    "                      \"scene.camera.up\":  {\"x\": 0, \"y\": 1, \"z\": 0}}]\n",
    "            ),\n",
    "            dict(\n",
    "              label=\"↗ 3D view\",\n",
    "              method=\"relayout\",\n",
    "              args=[{\"scene.camera.eye\": {\"x\": 1.8, \"y\": -1.8, \"z\": 1.2},\n",
    "                      \"scene.camera.up\":  {\"x\": 0, \"y\":  0, \"z\": 1}}]\n",
    "            ),\n",
    "          ]\n",
    "        ),\n",
    "    ],\n",
    "  )\n",
    ")\n",
